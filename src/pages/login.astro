---
// Locale
import nl from "@lib/copy/nl.js";

// Layouts
import LoginLayout from "@layouts/LoginLayout.astro";

// Components
import LoginForm from "@components/auth/LoginForm.astro";
---

<LoginLayout title={nl.pages.login}>
  <main
    class="flex flex-1 flex-col justify-center p-6 h-full"
    x-data="loginPage()"
  >
    <h1 class="mb-6 text-center text-xl font-semibold text-slate-100">
      {nl.app.title}
    </h1>
    <LoginForm />
  </main>
  <script>
    import { isLoggedIn } from "@lib/auth/session.client.js";

    if (isLoggedIn()) {
      window.location.replace("/");
    }
  </script>
</LoginLayout>

---
import CatalogForm from "@forms/CatalogForm.astro";
import nl from "@lib/copy/nl.js";

const confirmLabel = `'${nl.confirms.catalogEdit}'`;
const saveLabel = `'${nl.buttons.save}'`;
const cancelLabel = `'${nl.buttons.cancel}'`;
---

<div class="flex h-full min-h-0 flex-col overflow-hidden">
  <div
    x-show="!editConfirmPending"
    x-cloak
    class="flex min-h-0 flex-1 flex-col overflow-hidden"
  >
    <CatalogForm submitPrevent="requestCatalogEditSave()" />
  </div>
  <div x-show="editConfirmPending" x-cloak class="space-y-3">
    <p class="text-sm text-slate-200" x-text={confirmLabel}></p>
    <div class="flex gap-2">
      <button
        type="button"
        class="flex-1 rounded-app bg-accent px-3 py-2 text-sm font-medium text-accent-foreground"
        @click="confirmCatalogEditSave()"
        x-text={saveLabel}
      >
      </button>
      <button
        type="button"
        class="flex-1 rounded-app border border-slate-700 px-3 py-2 text-sm text-slate-300"
        @click="cancelCatalogEditConfirm()"
        x-text={cancelLabel}
      >
      </button>
    </div>
  </div>
</div>

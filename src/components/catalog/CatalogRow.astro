---
// Locale
import nl from "@lib/copy/nl.js";

interface Props {
  line: string;
  editClick: string;
}

// Props
const { line, editClick }: Props = Astro.props;
---

<li
  class="flex items-center justify-between gap-3 border-b border-slate-800 py-3 last:border-0"
>
  <p class="min-w-0 flex-1 text-sm text-slate-100" x-text={line}></p>
  <button
    type="button"
    class="shrink-0 text-sm text-accent hover:underline"
    @click={editClick}
    x-text={`'${nl.buttons.edit}'`}
  >
  </button>
</li>

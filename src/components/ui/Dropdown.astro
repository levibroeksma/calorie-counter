---
// Interface
interface Props {
  label: string;
  model: string;
  options: Array<{ label: string; value: string }>;
}

// Props
const { label, model, options }: Props = Astro.props;
---

<div x-data="{ open: false }" @click.outside="open = false" class="block">
  <span class="mb-1 block text-sm text-slate-300" x-text={label}></span>
  <button
    type="button"
    x-ref="trigger"
    class={" w-full rounded-app border border-slate-700 bg-slate-900 px-3 py-2 text-slate-100 flex items-center justify-between gap-2 text-left"}
    @click="open = !open"
    :aria-expanded="open"
  >
    {
      options.map((option) => (
        <span
          x-show={`${model} === '${option.value}'`}
          x-text={option.label}
        />
      ))
    }
    <svg
      class="size-4 shrink-0 text-slate-400"
      viewBox="0 0 20 20"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        fill-rule="evenodd"
        d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z"
        clip-rule="evenodd"
      />
    </svg>
  </button>
  <ul
    x-show="open"
    x-cloak
    x-anchor.fixed.bottom-start.offset.4="$refs.trigger"
    class="z-50 max-h-48 overflow-y-auto rounded-app border border-slate-700 bg-slate-900 py-1 shadow-lg"
  >
    {
      options.map((option) => (
        <li>
          <button
            type="button"
            class="w-full px-3 py-2 text-left text-slate-100 hover:bg-slate-800"
            @click={`${model} = '${option.value}'; open = false`}
            :class={`${model} === '${option.value}' ? 'bg-slate-800' : ''`}
            x-text={option.label}
          />
        </li>
      ))
    }
  </ul>
</div>

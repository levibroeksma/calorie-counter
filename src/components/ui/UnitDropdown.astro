---
import nl from "@lib/copy/nl.js";
import ChevronDown from "@icons/ChevronDown.astro";

const unitObject =   {
    label: `'${nl.forms.amount}'`,
    model: "$store.modalStore.form.referenceAmount",
    htmlType: "number",
    min: "1",
    step: "1",
  };
const dropdownOptions = {
    label: `'${nl.forms.unit}'`,
    model: "$store.modalStore.form.referenceUnit",
    htmlType: "select",
    options: [
      { label: `'${nl.units.grams}'`, value: "g" },
      { label: `'${nl.units.milliliters}'`, value: "ml" },
    ],
  };
---

<label class="w-1/5">
    <span class="mb-1 block text-sm text-slate-300" x-text={`${unitObject.label} + '/' + ${dropdownOptions.label}`}></span>
</label>
<div class="flex w-full">
    <input
        class="w-full rounded-l-app border border-slate-700 bg-slate-900 px-3 py-2 text-slate-100"
        type="number"
        x-model={unitObject.model}
        step="1"
        min="1"
    />

    <div x-data="{ open: false }" @click.outside="open = false" class="w-1/5">
        <button
            type="button"
            x-ref="trigger"
            class="w-full rounded-r-app h-full translate-x-[-1px] border border-slate-700 bg-slate-900 px-3 py-2 text-slate-100 flex items-center justify-between gap-2 text-left"
            @click="open = !open"
        >
        {
            dropdownOptions.options.map((option) => (
            <span
                x-show={`${dropdownOptions.model} === '${option.value}'`}
                x-text={option.label}
            />
            ))
        }
        <ChevronDown class="size-4 shrink-0 text-slate-400" />
        </button>
        <ul
            x-show="open"
            x-cloak
            x-anchor.fixed.bottom-start.offset.4="$refs.trigger"
            class="z-50 max-h-48 overflow-y-auto rounded-app border border-slate-700 bg-slate-900 py-1 shadow-lg"
        >
        {
            dropdownOptions.options.map((option) => (
            <li>
                <button
                    type="button"
                    class="w-full px-3 py-2 text-left text-slate-100 hover:bg-slate-800"
                    @click={`${dropdownOptions.model} = '${option.value}'; open = false`}
                    :class={`${dropdownOptions.model} === '${option.value}' ? 'bg-slate-800' : ''`}
                    x-text={option.label}
                />
            </li>
            ))
        }
        </ul>
  </div>
  
</div>

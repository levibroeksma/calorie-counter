---
// Components
import ProgressBar from "@ui/ProgressBar.astro";
import Skeleton from "@ui/Skeleton.astro";
---

<section class="space-y-3">
  <div x-show="!$store.appStore.hydrated" class="space-y-3">
    {
      Array.from({ length: 5 }).map(() => (
        <div class="space-y-1">
          <div class="flex justify-between gap-2">
            <Skeleton class="h-4 w-20" />
            <Skeleton class="h-4 w-24" />
          </div>
          <Skeleton class="h-2 w-full rounded-full" />
        </div>
      ))
    }
  </div>
  <div x-show="$store.appStore.hydrated" x-cloak class="space-y-3">
    <template x-for="(stat, index) in macroStats" :key="stat.key">
      <ProgressBar
        title="stat.label"
        value="stat.achieved"
        target="stat.target"
        targetLabel="stat.targetLabel"
        fillClass="stat.fillClass"
      />
    </template>
  </div>
</section>

---
// Locale
import nl from "@lib/copy/nl.js";

// Components
import UnitDropdown from "@ui/UnitDropdown.astro";

// Data
const unitDropdown = {
  unitObject: {
    label: `'${nl.forms.amount}'`,
    model: "$store.appStore.ui.portionAmount",
    min: "1",
    step: "1",
    required: true,
  },
  dropdownOptions: {
    label: `'${nl.forms.unit}'`,
    model: "$store.appStore.ui.portionUnit",
    options: [
      { label: `'${nl.units.grams}'`, value: "g" },
      { label: `'${nl.units.milliliters}'`, value: "ml" },
    ],
    disabled: "$store.appStore.getSelectedItem() != null",
  },
};
---

<div
  x-show="$store.appStore.ui.comboboxSelectedId != null"
  x-cloak
  class="mt-4 space-y-3 rounded-app border border-slate-800 p-3"
>
  <UnitDropdown data={unitDropdown} />
  <div
    x-show="$store.appStore.getPortionPreview()"
    x-cloak
    class="text-sm text-slate-400"
  >
    <span class="text-slate-500" x-text={`'${nl.forms.portionPreview}'`}></span>
    <span class="ml-1" x-text="portionPreviewText"></span>
  </div>
</div>

---
// Icons
import TrashCan from "@icons/TrashCan.astro";

// Interface
interface Props {
  name: string;
  portion: string;
  calories: string;
  removeClick: string;
}

// Props
const { name, portion, calories, removeClick }: Props = Astro.props;
---

<li
  class="flex items-center justify-between gap-3 border-b border-slate-800 py-3 last:border-0"
>
  <div class="min-w-0 flex-1">
    <p class="truncate text-sm font-medium text-slate-100" x-text={name}></p>
    <p class="text-sm text-slate-400" x-text={portion}></p>
    <p class="text-xs text-slate-500" x-text={calories}></p>
  </div>
  <button
    type="button"
    class="shrink-0 text-sm text-danger hover:underline hover:bg-danger/10 p-3 rounded-app"
    @click={removeClick}
  >
    <TrashCan class="size-5" />
  </button>
</li>

---
const { name, portion, calories, removeClick } = Astro.props;
---

<li
  class="flex items-start justify-between gap-3 border-b border-slate-800 py-3 last:border-0"
>
  <div class="min-w-0 flex-1">
    <p class="truncate text-sm font-medium text-slate-100" x-text={name}></p>
    <p class="text-sm text-slate-400" x-text={portion}></p>
    <p class="text-xs text-slate-500" x-text={calories}></p>
  </div>
  <button
    type="button"
    class="shrink-0 text-sm text-danger hover:underline"
    @click={removeClick}
  >
    ×
  </button>
</li>

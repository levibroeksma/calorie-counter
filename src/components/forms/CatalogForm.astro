---
import Button from "@ui/Button.astro";
import Input from "@ui/Input.astro";
import nl from "@lib/copy/nl.js";
import UnitDropdown from "@ui/UnitDropdown.astro";

const { submitPrevent } = Astro.props;

const inputFields = [
  {
    label: `'${nl.macros.calories}'`,
    model: "$store.modalStore.form.macros.calories",
    htmlType: "number",
    min: "0",
    step: "0.1",
  },
  {
    label: `'${nl.macros.protein}'`,
    model: "$store.modalStore.form.macros.protein",
    htmlType: "number",
    min: "0",
    step: "0.1",
  },
  {
    label: `'${nl.macros.fibres}'`,
    model: "$store.modalStore.form.macros.fibres",
    htmlType: "number",
    min: "0",
    step: "0.1",
  },
  {
    label: `'${nl.macros.fats}'`,
    model: "$store.modalStore.form.macros.fats",
    htmlType: "number",
    min: "0",
    step: "0.1",
  },
  {
    label: `'${nl.macros.carbs}'`,
    model: "$store.modalStore.form.macros.carbs",
    htmlType: "number",
    min: "0",
    step: "0.1",
  },
];

const unitDropdown = {
  unitObject: {
    label: `'${nl.forms.amount}'`,
    model: "$store.modalStore.form.referenceAmount",
    htmlType: "number",
    min: "1",
    step: "1",
  },
  dropdownOptions: {
    label: `'${nl.forms.unit}'`,
    model: "$store.modalStore.form.referenceUnit",
    htmlType: "select",
    options: [
      { label: `'${nl.units.grams}'`, value: "g" },
      { label: `'${nl.units.milliliters}'`, value: "ml" },
    ],
  },
};
---

<form
  class="min-h-0 flex-1 space-y-3 overflow-y-auto overscroll-contain pr-2"
  @submit.prevent={submitPrevent}
>
  <Input label={`'${nl.forms.name}'`} model="$store.modalStore.form.name" />
  <UnitDropdown data={unitDropdown} />
  {
    inputFields.map((field) => (
      <Input
        label={field.label}
        model={field.model}
        htmlType={field.htmlType as "number" | "text"}
        min={field.min}
        step={field.step}
      />
    ))
  }
  <Button
    text={`'${nl.buttons.save}'`}
    type="submit"
    :disabled="$store.appStore.isSaving"
  />
</form>

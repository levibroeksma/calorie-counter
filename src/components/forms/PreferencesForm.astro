---
// Locale
import nl from "@lib/copy/nl.js";

// Components
import Input from "@ui/Input.astro";
import Skeleton from "@ui/Skeleton.astro";
---

<div x-show="!$store.appStore.hydrated" class="space-y-4">
  <h2 class="text-base font-medium text-slate-200">
    {nl.forms.targetsTitle}
  </h2>
  {
    Array.from({ length: 5 }).map(() => (
      <div class="space-y-1">
        <Skeleton class="h-4 w-24" />
        <Skeleton class="h-[42px] w-full rounded-app" />
      </div>
    ))
  }
  <Skeleton class="h-[42px] w-full rounded-app" />
</div>
<form
  x-show="$store.appStore.hydrated"
  x-cloak
  @submit.prevent="save()"
  class="flex flex-col gap-2 rounded-app"
>
  <h2 class="text-base font-medium text-slate-200">
    {nl.forms.targetsTitle}
  </h2>
  <Input
    label={nl.targets.calories}
    model="form.targetCalories"
    htmlType="number"
    min="0"
    step="0.1"
  />
  <Input
    label={nl.targets.protein}
    model="form.targetProtein"
    htmlType="number"
    min="0"
    step="0.1"
  />
  <Input
    label={nl.targets.fibres}
    model="form.targetFibres"
    htmlType="number"
    min="0"
    step="0.1"
  />
  <Input
    label={nl.targets.fats}
    model="form.targetFats"
    htmlType="number"
    min="0"
    step="0.1"
  />
  <Input
    label={nl.targets.carbs}
    model="form.targetCarbs"
    htmlType="number"
    min="0"
    step="0.1"
  />

  <button
    type="submit"
    class={`inline-flex min-h-11 mt-4 w-full items-center justify-center rounded-app px-4 py-2 text-sm font-medium touch-manipulation disabled:opacity-50 bg-accent text-accent-foreground`}
    :disabled="$store.appStore.isSaving"
  >
    <span>{nl.buttons.save}</span>
  </button>
</form>

---
import BaseLayout from "@layouts/BaseLayout.astro";
import Toast from "@ui/Toast.astro";
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<BaseLayout title={title}>
  <Toast />
  <div
    class="mx-auto flex-1 w-full max-w-lg pb-[calc(var(--spacing-nav-height)+var(--spacing-safe-bottom))]"
  >
    <slot />
  </div>
</BaseLayout>
